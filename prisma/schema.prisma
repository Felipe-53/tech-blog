// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TechNote {
  id         Int                  @id @default(autoincrement())
  title      String
  created_at DateTime             @default(now())
  body       String
  categories TechNoteOnCategory[]

  @@map("tech_notes")
}

model TechNoteCategory {
  id        Int                  @id @default(autoincrement())
  name      String
  techNotes TechNoteOnCategory[]

  @@map("tech_note_categories")
}

model TechNoteOnCategory {
  tech_note_id Int
  category_id  Int
  techNote     TechNote         @relation(fields: [tech_note_id], references: [id])
  category     TechNoteCategory @relation(fields: [category_id], references: [id])

  @@id([tech_note_id, category_id])
  @@map("tech_note_on_category")
}
